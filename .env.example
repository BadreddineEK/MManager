# ════════════════════════════════════════════════════════════════════════════
#  Mosquée Manager — Variables d'environnement
#  Copier ce fichier en .env et remplir TOUTES les valeurs marquées CHANGE_MOI
#  ⚠️  Ne JAMAIS commiter .env dans le repo (voir .gitignore)
# ════════════════════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=CHANGE_MOI_cle_secrete_tres_longue_et_aleatoire

# DEV  : True  (hot-reload, erreurs détaillées, BrowsableAPI)
# PROD : False (sécurité activée, JSON pur, logs structurés)
DJANGO_DEBUG=False

# IP locale du Pi + domaine ngrok (séparés par virgules, sans espaces)
# Trouver l'IP avec : hostname -I | awk '{print $1}'
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.X.XX,ton-domaine.ngrok-free.app

# ── Base de données ────────────────────────────────────────────────────────────
POSTGRES_DB=mosque_db
POSTGRES_USER=mosque_user
# Générer avec : python3 -c "import secrets; print(secrets.token_urlsafe(20))"
POSTGRES_PASSWORD=CHANGE_MOI_mot_de_passe_postgres_fort
# Format : postgres://USER:PASSWORD@HOST:PORT/DBNAME
# En Docker : HOST = nom du service = "db"
DATABASE_URL=postgres://mosque_user:CHANGE_MOI_mot_de_passe_postgres_fort@db:5432/mosque_db

# ── CSRF & CORS ───────────────────────────────────────────────────────────────
# Lister toutes les URLs depuis lesquelles l'app est accédée
CSRF_TRUSTED_ORIGINS=http://localhost,http://192.168.X.XX,https://ton-domaine.ngrok-free.app
CORS_ALLOWED_ORIGINS=http://localhost,http://192.168.X.XX,https://ton-domaine.ngrok-free.app

# ── ngrok (accès depuis l'extérieur — gratuit, sans CB) ──────────────────────
# 1. Créer un compte sur https://ngrok.com (gratuit, connexion Google/GitHub)
# 2. Récupérer le token sur https://dashboard.ngrok.com/authtokens
# 3. Récupérer ton domaine statique sur https://dashboard.ngrok.com/domains
NGROK_AUTHTOKEN=CHANGE_MOI
NGROK_DOMAIN=ton-domaine.ngrok-free.app

# ── Cloudflare Tunnel (optionnel — alternative à ngrok si vous avez un domaine)
# Laisser vide si vous utilisez ngrok
CLOUDFLARE_TUNNEL_TOKEN=

# ── Cookies sécurisés ─────────────────────────────────────────────────────────
# false = accès HTTP local (réseau WiFi mosquée)
# true  = accès HTTPS via ngrok/Cloudflare (activer une fois ngrok configuré)
HTTPS_ENABLED=true

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_PASSPHRASE=CHANGE_MOI_passphrase_backup_longue_et_aleatoire
BACKUP_TARGET=local

# ── Internationalisation ──────────────────────────────────────────────────────
TIMEZONE=Europe/Paris

