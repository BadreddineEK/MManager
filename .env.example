# ─────────────────────────────────────────────────────────────────────────────
# Mosquée Manager — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ⚠️  Ne JAMAIS commiter .env dans le repo (voir .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Générer une clé avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE_MOI_cle_secrete_tres_longue_et_aleatoire

# DEV  : True  (hot-reload, erreurs détaillées, BrowsableAPI)
# PROD : False (sécurité activée, JSON pur, logs structurés)
DJANGO_DEBUG=True

# DEV  : localhost,127.0.0.1
# PROD : ajouter votre domaine, ex: mosque.votredomaine.com
ALLOWED_HOSTS=localhost,127.0.0.1

# PROD uniquement — origine(s) autorisées pour les requêtes CORS
# (laisser vide en dev, CORS_ALLOW_ALL_ORIGINS=True est activé si DEBUG=True)
# Exemple : CORS_ALLOWED_ORIGINS=https://mosque.votredomaine.com
CORS_ALLOWED_ORIGINS=

# ── Base de données ────────────────────────────────────────────────────────────
POSTGRES_DB=mosque_db
POSTGRES_USER=mosque_user
POSTGRES_PASSWORD=CHANGE_MOI_mot_de_passe_postgres_fort
# Format : postgres://USER:PASSWORD@HOST:PORT/DBNAME
# En Docker : HOST = nom du service = "db"
DATABASE_URL=postgres://mosque_user:CHANGE_MOI_mot_de_passe_postgres_fort@db:5432/mosque_db

# ── Mosquée par défaut (onboarding) ──────────────────────────────────────────
DEFAULT_MOSQUE_SLUG=meximieux

# ── Superutilisateur initial ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@mosquee.fr
ADMIN_PASSWORD=ChangeMe123!

# ── Cloudflare Tunnel (prod uniquement) ──────────────────────────────────────
# 1. Créer un tunnel sur https://one.dash.cloudflare.com → Zero Trust → Tunnels
# 2. Copier le token ici
# 3. Configurer le tunnel pour pointer vers : http://nginx:80
CLOUDFLARE_TUNNEL_TOKEN=

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_PASSPHRASE=CHANGE_MOI_passphrase_backup_longue_et_aleatoire
# Options : "local" ou "s3"
BACKUP_TARGET=local

# AWS S3 (uniquement si BACKUP_TARGET=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ── Internationalisation ──────────────────────────────────────────────────────
TIMEZONE=Europe/Paris

